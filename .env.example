# .env.example — Copier en .env.local, ne JAMAIS commiter .env.local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic (Claude IA)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (monétisation SaaS)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_FAMILY_PRO_PRICE_ID=price_...

# Open Banking — Bridge API
BRIDGE_CLIENT_ID=...
BRIDGE_CLIENT_SECRET=...
BRIDGE_API_URL=https://api.bridgeapi.io
BRIDGE_WEBHOOK_SECRET=...

# Email (Resend)
RESEND_API_KEY=re_...

# SMS (Twilio — alertes critiques)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+33...

# Google Calendar (sync)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# Mon Espace Santé (FHIR R4)
MES_FHIR_BASE_URL=https://gateway.api.esante.gouv.fr/fhir/v1
MES_CLIENT_ID=
MES_CLIENT_SECRET=
MES_REDIRECT_URI=https://darons.app/api/health/fhir/callback
PRO_SANTE_CONNECT_URL=https://auth.esante.gouv.fr

# App
NEXT_PUBLIC_APP_URL=https://darons.app
NEXT_PUBLIC_APP_NAME=Darons
