# ============================================================================
# DARONS.APP — Template de configuration production
# ============================================================================
# Copier ce fichier en .env.local :  cp .env.local.template .env.local
# JAMAIS commiter .env.local !
# ============================================================================

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ TIER 1 — CRITIQUE (obligatoire pour que le site fonctionne)            │
# └──────────────────────────────────────────────────────────────────────────┘

# Supabase — https://supabase.com/dashboard/project/[ref]/settings/api
# Creer un projet sur supabase.com, copier les cles depuis Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://[votre-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App
NEXT_PUBLIC_APP_URL=https://darons.app
NEXT_PUBLIC_APP_NAME=Darons

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ TIER 2 — IMPORTANT (fonctionnalites cles)                              │
# └──────────────────────────────────────────────────────────────────────────┘

# Anthropic (Claude IA) — https://console.anthropic.com/settings/keys
# Coach budget, alertes proactives, suggestions activites
ANTHROPIC_API_KEY=sk-ant-...

# Resend (emails) — https://resend.com/api-keys
# Necessaire pour magic link, notifications, recaps mensuels
# IMPORTANT : verifier le domaine darons.app dans Resend > Domains
RESEND_API_KEY=re_...

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ TIER 3 — MONETISATION (Stripe)                                         │
# └──────────────────────────────────────────────────────────────────────────┘

# Stripe — https://dashboard.stripe.com/apikeys
# Mode test d'abord (sk_test_...), puis live quand pret
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook — https://dashboard.stripe.com/webhooks
# URL du webhook : https://darons.app/api/webhooks/stripe
# Events : checkout.session.completed, customer.subscription.updated,
#          customer.subscription.deleted, invoice.payment_failed, invoice.paid
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — https://dashboard.stripe.com/products
# Creer 2 produits recurrents :
#   - "Darons+" a 4,99 EUR/mois
#   - "Darons Family Pro" (prix a definir)
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_FAMILY_PRO_PRICE_ID=price_...

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ TIER 4 — FEATURES AVANCEES                                             │
# └──────────────────────────────────────────────────────────────────────────┘

# Bridge API (Open Banking) — https://bridgeapi.io
# Demander un acces sandbox via le formulaire de contact
# Webhook URL : https://darons.app/api/webhooks/bridge
BRIDGE_CLIENT_ID=
BRIDGE_CLIENT_SECRET=
BRIDGE_API_URL=https://api.bridgeapi.io
BRIDGE_WEBHOOK_SECRET=

# Google Calendar — https://console.cloud.google.com/apis/credentials
# Activer Google Calendar API, creer OAuth 2.0 Client ID (Web application)
# Redirect URI : https://darons.app/api/calendar/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Twilio (SMS alertes critiques) — https://console.twilio.com
# Acheter un numero francais (+33...)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ TIER 5 — POST-LANCEMENT                                                │
# └──────────────────────────────────────────────────────────────────────────┘

# Web Push (VAPID keys)
# Generer avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Sentry (monitoring erreurs) — https://sentry.io
# npm install @sentry/nextjs && npx @sentry/wizard@latest -i nextjs
SENTRY_DSN=

# Upstash Redis (rate limiting production) — https://console.upstash.com
# npm install @upstash/ratelimit @upstash/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OCR (optionnel — Tesseract.js fonctionne sans)
# Google Vision API pour OCR de meilleure qualite
GOOGLE_VISION_API_KEY=

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ BLOQUE — Services necessitant des autorisations reglementaires         │
# └──────────────────────────────────────────────────────────────────────────┘

# Mon Espace Sante (FHIR) — Necessite referencement ANS + certification HDS
# Ne PAS activer sans les autorisations requises
# MES_FHIR_BASE_URL=https://gateway.api.esante.gouv.fr/fhir/v1
# MES_CLIENT_ID=
# MES_CLIENT_SECRET=
# MES_REDIRECT_URI=https://darons.app/api/health/fhir/callback
# PRO_SANTE_CONNECT_URL=https://auth.esante.gouv.fr

# API Particulier (DINUM) — Reserve aux acteurs publics
# API_PARTICULIER_TOKEN=
